        },
        "type": "object",
        "required": [
          "report_id",
          "created_at",
          "business_name",
          "business_address"
        ],
        "title": "KybReportStatusProcessing"
      },
      "UsKybAddressRequest": {
        "properties": {
          "address_line1": {
            "type": "string",
            "minLength": 1,
