          },
          "city": {
            "type": "string",
            "minLength": 1,
            "title": "City"
          },
          "state": {
            "type": "string",
            "minLength": 1,
            "title": "State"
          },
          "postal_code": {
            "type": "string",
            "minLength": 1,
            "title": "Postal Code"
          },
          "country_code": {
            "type": "string",
            "minLength": 1,
